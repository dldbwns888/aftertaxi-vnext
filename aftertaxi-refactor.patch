-    """
-    import warnings
-
-    if mode == "decision_support":
-        if data_source == "synthetic":
-            warnings.warn(
-                "decision_support 모드에서 합성 데이터 사용. "
-                "실제 데이터(yfinance)로 재검증을 강력히 권장합니다.",
